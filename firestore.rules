            'name',
            'description',
            'jobType',
            'targetType',
            'targetId',
            'pageId',
            'targetUrl',
            'scheduleType',
            'triggerType',
            'executionMode',
            'priority',
            'status',
            'nextRunAt',
            'lastRunAt',
            'lastRunId',
            'lastRunStatus',
            'totalRunCount',
            'successCount',
            'partialSuccessCount',
            'failureCount',
            'blockedCount',
            'consecutiveFailureCount',
            'maxRetryCount',
            'retryDelayMinutes',
            'leaseOwner',
            'leaseAcquiredAt',
            'leaseExpiresAt',
            'lastRequestedAt',
            'lastRequestedBy',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])
          && request.resource.data.keys().hasOnly([
            'tenantId',
            'brandId',
            'profileId',
            'sourceId',
            'name',
            'description',
            'jobType',
            'targetType',
            'targetId',
            'pageId',
            'targetUrl',
            'scheduleType',
            'triggerType',
            'executionMode',
            'priority',
            'status',
            'nextRunAt',
            'lastRunAt',
            'lastRunId',
            'lastRunStatus',
            'totalRunCount',
            'successCount',
            'partialSuccessCount',
            'failureCount',
            'blockedCount',
            'consecutiveFailureCount',
            'maxRetryCount',
            'retryDelayMinutes',
            'leaseOwner',
            'leaseAcquiredAt',
            'leaseExpiresAt',
            'lastRequestedAt',
            'lastRequestedBy',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])

          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.tenantId.size() > 0

          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.profileId is string
          && request.resource.data.profileId.size() > 0
          && request.resource.data.sourceId is string
          && request.resource.data.sourceId.size() > 0

          && request.resource.data.name is string
          && request.resource.data.name.size() >= 2
          && request.resource.data.name.size() <= 200

          && (
            request.resource.data.description == null
            || (
              request.resource.data.description is string
              && request.resource.data.description.size() <= 2000
            )
          )

          && request.resource.data.jobType in [
            'source_discovery',
            'keyword_search',
            'page_scan',
            'seller_scan',
            'store_scan',
            'price_scan',
            'manual_scan'
          ]

          && request.resource.data.targetType in [
            'source',
            'page',
            'seller',
            'store',
            'query',
            'listing'
          ]

          && request.resource.data.targetId is string
          && request.resource.data.targetId.size() > 0

          && (
            request.resource.data.pageId == null
            || (
              request.resource.data.pageId is string
              && request.resource.data.pageId.size() > 0
            )
          )

          && (
            request.resource.data.targetUrl == null
            || (
              request.resource.data.targetUrl is string
              && request.resource.data.targetUrl.size() <= 3000
            )
          )

          && request.resource.data.scheduleType in [
            'manual',
            'hourly',
            'every_6_hours',
            'daily',
            'weekly',
            'custom'
          ]

          && request.resource.data.triggerType in [
            'scheduled',
            'manual',
            'retry',
            'webhook',
            'system_recovery'
          ]

          && request.resource.data.executionMode in [
            'queue',
            'n8n',
            'worker',
            'manual'
          ]

          && request.resource.data.priority in [
            'low',
            'normal',
            'high',
            'critical'
          ]

          && request.resource.data.status in [
            'draft',
            'active',
            'paused',
            'disabled',
            'archived'
          ]

          && request.resource.data.lastRunStatus == 'never_run'
          && request.resource.data.lastRunAt == null
          && request.resource.data.lastRunId == null

          && request.resource.data.totalRunCount == 0
          && request.resource.data.successCount == 0
          && request.resource.data.partialSuccessCount == 0
          && request.resource.data.failureCount == 0
          && request.resource.data.blockedCount == 0
          && request.resource.data.consecutiveFailureCount == 0

          && request.resource.data.maxRetryCount is int
          && request.resource.data.maxRetryCount >= 0
          && request.resource.data.maxRetryCount <= 20

          && request.resource.data.retryDelayMinutes is int
          && request.resource.data.retryDelayMinutes >= 1
          && request.resource.data.retryDelayMinutes <= 1440

          && request.resource.data.leaseOwner == null
          && request.resource.data.leaseAcquiredAt == null
          && request.resource.data.leaseExpiresAt == null
          && request.resource.data.lastRequestedAt == null
          && request.resource.data.lastRequestedBy == null

          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy == request.auth.uid

          && (
            request.resource.data.updatedAt == null
            || request.resource.data.updatedAt is timestamp
          )

          && (
            request.resource.data.updatedBy == null
            || request.resource.data.updatedBy == request.auth.uid
          );

      // Görev tanımının marka kullanıcısı tarafından düzenlenebilen alanları.
      // Operasyon sayaçları, çalışma sonucu ve lease alanları bu dalda değişemez.
      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.profileId == resource.data.profileId
          && request.resource.data.sourceId == resource.data.sourceId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy

          && (
            (
              request.resource.data.diff(resource.data)
                  .affectedKeys()
                  .hasOnly([
                    'name',
                    'description',
                    'jobType',
                    'targetType',
                    'targetId',
                    'pageId',
                    'targetUrl',
                    'scheduleType',
                    'triggerType',
                    'executionMode',
                    'priority',
                    'status',
                    'nextRunAt',
                    'maxRetryCount',
                    'retryDelayMinutes',
                    'updatedAt',
                    'updatedBy'
                  ])

              && request.resource.data.name is string
              && request.resource.data.name.size() >= 2
              && request.resource.data.name.size() <= 200

              && (
                request.resource.data.description == null
                || (
                  request.resource.data.description is string
                  && request.resource.data.description.size() <= 2000
                )
              )

              && request.resource.data.jobType in [
                'source_discovery',
                'keyword_search',
                'page_scan',
                'seller_scan',
                'store_scan',
                'price_scan',
                'manual_scan'
              ]

              && request.resource.data.targetType in [
                'source',
                'page',
                'seller',
                'store',
                'query',
                'listing'
              ]

              && request.resource.data.targetId is string
              && request.resource.data.targetId.size() > 0

              && request.resource.data.scheduleType in [
                'manual',
                'hourly',
                'every_6_hours',
                'daily',
                'weekly',
                'custom'
              ]

              && request.resource.data.triggerType in [
                'scheduled',
                'manual',
                'retry',
                'webhook',
                'system_recovery'
              ]

              && request.resource.data.executionMode in [
                'queue',
                'n8n',
                'worker',
                'manual'
              ]

              && request.resource.data.priority in [
                'low',
                'normal',
                'high',
                'critical'
              ]

              && request.resource.data.status in [
                'draft',
                'active',
                'paused',
                'disabled',
                'archived'
              ]

              && (
                request.resource.data.status == resource.data.status
                || resource.data.leaseExpiresAt == null
                || resource.data.leaseExpiresAt <= request.time
              )

              && request.resource.data.maxRetryCount is int
              && request.resource.data.maxRetryCount >= 0
              && request.resource.data.maxRetryCount <= 20

              && request.resource.data.retryDelayMinutes is int
              && request.resource.data.retryDelayMinutes >= 1
              && request.resource.data.retryDelayMinutes <= 1440

              && request.resource.data.updatedAt == request.time
              && request.resource.data.updatedBy == request.auth.uid
            )

            ||

            // Manuel veya planlı kuyruk talebi.
            // Yalnız rezervasyon ve talep alanları değiştirilebilir.
            (
              request.resource.data.diff(resource.data)
                  .affectedKeys()
                  .hasOnly([
                    'triggerType',
                    'leaseOwner',
                    'leaseAcquiredAt',
                    'leaseExpiresAt',
                    'lastRequestedAt',
                    'lastRequestedBy',
                    'updatedAt',
                    'updatedBy'
                  ])

              && resource.data.status == 'active'

              && (
                resource.data.leaseExpiresAt == null
                || resource.data.leaseExpiresAt <= request.time
              )

              && request.resource.data.triggerType in [
                'scheduled',
                'manual',
                'retry',
                'webhook',
                'system_recovery'
              ]

              && request.resource.data.leaseOwner is string
              && request.resource.data.leaseOwner.matches('^queue:.+')

              && request.resource.data.leaseAcquiredAt is timestamp
              && request.resource.data.leaseAcquiredAt == request.time

              && request.resource.data.leaseExpiresAt is timestamp
              && request.resource.data.leaseExpiresAt > request.time

              && request.resource.data.lastRequestedAt is timestamp
              && request.resource.data.lastRequestedAt == request.time

              && request.resource.data.lastRequestedBy == request.auth.uid
              && request.resource.data.updatedAt == request.time
              && request.resource.data.updatedBy == request.auth.uid
            )
          );

      // Geçmişi bulunan görevler silinmez; arşivlenir.
      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.totalRunCount == 0
          && resource.data.lastRunId == null
          && (
            resource.data.leaseExpiresAt == null
            || resource.data.leaseExpiresAt <= request.time
          );
    }

    match /monitoring_crawl_runs/{runId} {
      // Deterministik tenant-safe belge kimliği sayesinde, henüz mevcut
      // olmayan run kaydı idempotency kontrolü için okunabilir.
      allow get: if request.auth != null
          && runId.matches('^' + request.auth.uid + '__.+$');

      // Koleksiyon sorguları mutlaka tenantId filtresiyle yapılmalıdır.
      allow list: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      // Marka istemcisi yalnız queued çalışma talebi oluşturabilir.
      // Running ve sonuç durumları güvenilir worker/Admin SDK tarafından yazılır.
      allow create: if request.auth != null
          && request.resource.data.keys().hasAll([
            'tenantId',
            'brandId',
            'profileId',
            'jobId',
            'sourceId',
            'targetId',
            'pageId',
            'triggerType',
            'triggeredBy',
            'requestKey',
            'queuedAt',
            'startedAt',
            'completedAt',
            'runStatus',
            'workerId',
            'executionAttempt',
            'httpStatus',
            'itemsFound',
            'snapshotsCreated',
            'eventsCreated',
            'signalsCreated',
            'bytesDownloaded',
            'durationMs',
            'errorCode',
            'errorMessage',
            'collectorVersion',
            'parserVersion',
            'createdAt'
          ])
          && request.resource.data.keys().hasOnly([
            'tenantId',
            'brandId',
            'profileId',
            'jobId',
            'sourceId',
            'targetId',
            'pageId',
            'triggerType',
            'triggeredBy',
            'requestKey',
            'queuedAt',
            'startedAt',
            'completedAt',
            'runStatus',
            'workerId',
            'executionAttempt',
            'httpStatus',
            'itemsFound',
            'snapshotsCreated',
            'eventsCreated',
            'signalsCreated',
            'bytesDownloaded',
            'durationMs',
            'errorCode',
            'errorMessage',
            'collectorVersion',
            'parserVersion',
            'createdAt'
          ])

          && request.resource.data.tenantId == request.auth.uid
          && runId.matches('^' + request.auth.uid + '__.+$')
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.profileId is string
          && request.resource.data.profileId.size() > 0
          && request.resource.data.jobId is string
          && request.resource.data.jobId.size() > 0
          && request.resource.data.sourceId is string
          && request.resource.data.sourceId.size() > 0
          && request.resource.data.targetId is string
          && request.resource.data.targetId.size() > 0

          && request.resource.data.triggerType in [
            'scheduled',
            'manual',
            'retry',
            'webhook',
            'system_recovery'
          ]

          && request.resource.data.triggeredBy == request.auth.uid
          && request.resource.data.requestKey is string
          && request.resource.data.requestKey.size() > 0
          && request.resource.data.requestKey.size() <= 240

          && request.resource.data.queuedAt is timestamp
          && request.resource.data.queuedAt == request.time
          && request.resource.data.runStatus == 'queued'

          && request.resource.data.startedAt == null
          && request.resource.data.completedAt == null
          && request.resource.data.workerId == null
          && request.resource.data.httpStatus == null

          && request.resource.data.executionAttempt == 1
          && request.resource.data.itemsFound == 0
          && request.resource.data.snapshotsCreated == 0
          && request.resource.data.eventsCreated == 0
          && request.resource.data.signalsCreated == 0

          && request.resource.data.bytesDownloaded == null
          && request.resource.data.durationMs == null
          && request.resource.data.errorCode == null
          && request.resource.data.errorMessage == null

          && request.resource.data.collectorVersion == 'pending'
          && request.resource.data.parserVersion == null
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdAt == request.time

          // Run talebi ile aynı transaction içinde görev rezervasyonu zorunludur.
          && exists(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          )

          && get(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.tenantId == request.auth.uid

          && get(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.status == 'active'

          && getAfter(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.leaseOwner == 'queue:' + runId

          && getAfter(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.lastRequestedBy == request.auth.uid

          && request.resource.data.brandId == get(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.brandId

          && request.resource.data.profileId == get(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.profileId

          && request.resource.data.sourceId == get(
            /databases/$(database)/documents/monitoring_crawl_jobs/$(request.resource.data.jobId)
          ).data.sourceId;

      allow update, delete: if false;
    }
    match /monitoring_signals/{signalId} {
      // Marka kullanıcısı yalnız kendi tenant sinyallerini okuyabilir.
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      // Sinyaller yalnız güvenilir n8n/worker tarafından,
      // Admin SDK üzerinden oluşturulur.
      allow create: if false;

      // 1. Kullanıcı inceleme durumunu değiştirebilir.
      //
      // Değiştirilebilen durumlar:
      // under_review, confirmed, dismissed, escalated, archived
      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.sourceId == resource.data.sourceId
          && request.resource.data.pageId == resource.data.pageId
          && request.resource.data.listingId == resource.data.listingId
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.storeId == resource.data.storeId
          && request.resource.data.eventId == resource.data.eventId
          && request.resource.data.ruleId == resource.data.ruleId
          && request.resource.data.ruleName == resource.data.ruleName
          && request.resource.data.eventType == resource.data.eventType
          && request.resource.data.eventCategory
              == resource.data.eventCategory
          && request.resource.data.signalLevel == resource.data.signalLevel
          && request.resource.data.forwardingStatus
              == resource.data.forwardingStatus
          && request.resource.data.forwardedAt == resource.data.forwardedAt
          && request.resource.data.forwardingError
              == resource.data.forwardingError
          && request.resource.data.title == resource.data.title
          && request.resource.data.summary == resource.data.summary
          && request.resource.data.detectedAt == resource.data.detectedAt
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.resolvedAt == resource.data.resolvedAt
          && request.resource.data.resolvedBy == resource.data.resolvedBy
          && request.resource.data.resolutionNote
              == resource.data.resolutionNote
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'reviewedAt',
            'reviewedBy',
            'updatedAt',
            'updatedBy'
          ])
          && request.resource.data.status in [
            'under_review',
            'confirmed',
            'dismissed',
            'escalated',
            'archived'
          ]
          && request.resource.data.reviewedAt is timestamp
          && request.resource.data.reviewedBy == request.auth.uid
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == request.auth.uid;

      // 2. Kullanıcı sinyali açıklama notuyla çözebilir.
      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.sourceId == resource.data.sourceId
          && request.resource.data.pageId == resource.data.pageId
          && request.resource.data.listingId == resource.data.listingId
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.storeId == resource.data.storeId
          && request.resource.data.eventId == resource.data.eventId
          && request.resource.data.ruleId == resource.data.ruleId
          && request.resource.data.ruleName == resource.data.ruleName
          && request.resource.data.eventType == resource.data.eventType
          && request.resource.data.eventCategory
              == resource.data.eventCategory
          && request.resource.data.signalLevel == resource.data.signalLevel
          && request.resource.data.forwardingStatus
              == resource.data.forwardingStatus
          && request.resource.data.forwardedAt == resource.data.forwardedAt
          && request.resource.data.forwardingError
              == resource.data.forwardingError
          && request.resource.data.title == resource.data.title
          && request.resource.data.summary == resource.data.summary
          && request.resource.data.detectedAt == resource.data.detectedAt
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.reviewedAt == resource.data.reviewedAt
          && request.resource.data.reviewedBy == resource.data.reviewedBy
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'resolvedAt',
            'resolvedBy',
            'resolutionNote',
            'updatedAt',
            'updatedBy'
          ])
          && request.resource.data.status == 'resolved'
          && request.resource.data.resolvedAt is timestamp
          && request.resource.data.resolvedBy == request.auth.uid
          && request.resource.data.resolutionNote is string
          && request.resource.data.resolutionNote.size() > 0
          && request.resource.data.resolutionNote.size() <= 1000
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == request.auth.uid;

      // Sinyaller tarihsel kayıt olarak silinemez.
      allow delete: if false;
    }

    // ============================================================
    // FİKRİ MÜLKİYET VE BELGELER — ÇEKİRDEK VERİ KATMANI
    // tenantId, marka hesabının Firebase Auth UID değeridir.
    // Bu fazda yalnız dört aktif koleksiyon istemci erişimine açıktır.
    // ============================================================

    match /ip_assets/{assetId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.assetCode is string
          && request.resource.data.assetCode.size() > 0
          && request.resource.data.assetCode.size() <= 100
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 300
          && request.resource.data.rightStrengthScore is int
          && request.resource.data.rightStrengthScore >= 0
          && request.resource.data.rightStrengthScore <= 100
          && request.resource.data.secretSecurityScore is int
          && request.resource.data.secretSecurityScore >= 0
          && request.resource.data.secretSecurityScore <= 100
          && request.resource.data.responseReadinessScore is int
          && request.resource.data.responseReadinessScore >= 0
          && request.resource.data.responseReadinessScore <= 100
          && request.resource.data.resilienceScore is int
          && request.resource.data.resilienceScore >= 0
          && request.resource.data.resilienceScore <= 100
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && (
            request.resource.data.updatedBy == null
            || request.resource.data.updatedBy == request.auth.uid
          );

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.assetCode == resource.data.assetCode
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.rightStrengthScore is int
          && request.resource.data.rightStrengthScore >= 0
          && request.resource.data.rightStrengthScore <= 100
          && request.resource.data.secretSecurityScore is int
          && request.resource.data.secretSecurityScore >= 0
          && request.resource.data.secretSecurityScore <= 100
          && request.resource.data.responseReadinessScore is int
          && request.resource.data.responseReadinessScore >= 0
          && request.resource.data.responseReadinessScore <= 100
          && request.resource.data.resilienceScore is int
          && request.resource.data.resilienceScore >= 0
          && request.resource.data.resilienceScore <= 100
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.rightIds.size() == 0
          && resource.data.documentIds.size() == 0
          && resource.data.relationshipIds.size() == 0
          && resource.data.monitoringProfileIds.size() == 0;
    }

    match /ip_rights/{rightId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.assetId is string
          && request.resource.data.assetId.size() > 0
          && request.resource.data.rightCode is string
          && request.resource.data.rightCode.size() > 0
          && request.resource.data.rightCode.size() <= 100
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 300
          && request.resource.data.rightStrengthScore is int
          && request.resource.data.rightStrengthScore >= 0
          && request.resource.data.rightStrengthScore <= 100
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && (
            request.resource.data.updatedBy == null
            || request.resource.data.updatedBy == request.auth.uid
          );

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.assetId == resource.data.assetId
          && request.resource.data.rightCode == resource.data.rightCode
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.rightStrengthScore is int
          && request.resource.data.rightStrengthScore >= 0
          && request.resource.data.rightStrengthScore <= 100
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.documentIds.size() == 0
          && resource.data.relationshipIds.size() == 0
          && resource.data.relatedRightIds.size() == 0
          && resource.data.patentFamilyIds.size() == 0
          && resource.data.oppositionActive == false
          && resource.data.disputeActive == false
          && resource.data.customsProtectionActive == false;
    }

    match /ip_documents/{documentId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.documentCode is string
          && request.resource.data.documentCode.size() > 0
          && request.resource.data.documentCode.size() <= 100
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 300
          && request.resource.data.fileSizeBytes is int
          && request.resource.data.fileSizeBytes >= 0
          && request.resource.data.versionNumber is int
          && request.resource.data.versionNumber >= 1
          && (
            request.resource.data.sha256Hash == null
            || (
              request.resource.data.sha256Hash is string
              && request.resource.data.sha256Hash.matches(
                '^[A-Fa-f0-9]{64}$'
              )
            )
          )
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && (
            request.resource.data.updatedBy == null
            || request.resource.data.updatedBy == request.auth.uid
          );

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.documentCode == resource.data.documentCode
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.fileSizeBytes is int
          && request.resource.data.fileSizeBytes >= 0
          && request.resource.data.versionNumber is int
          && request.resource.data.versionNumber >= 1
          && (
            request.resource.data.sha256Hash == null
            || (
              request.resource.data.sha256Hash is string
              && request.resource.data.sha256Hash.matches(
                '^[A-Fa-f0-9]{64}$'
              )
            )
          )
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.legalHoldActive == false
          && resource.data.isLocked == false
          && resource.data.parentDocumentId == null
          && resource.data.previousVersionId == null
          && resource.data.supersedingDocumentId == null
          && resource.data.caseIds.size() == 0
          && resource.data.relatedAssetIds.size() == 0
          && resource.data.relatedRightIds.size() == 0
          && resource.data.relationshipIds.size() == 0;
    }

    match /ip_relationships/{relationshipId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.relationshipCode is string
          && request.resource.data.relationshipCode.size() > 0
          && request.resource.data.relationshipCode.size() <= 100
          && request.resource.data.subjectName is string
          && request.resource.data.subjectName.size() > 0
          && request.resource.data.subjectName.size() <= 300
          && request.resource.data.riskScore is int
          && request.resource.data.riskScore >= 0
          && request.resource.data.riskScore <= 100
          && request.resource.data.trustScore is int
          && request.resource.data.trustScore >= 0
          && request.resource.data.trustScore <= 100
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && (
            request.resource.data.updatedBy == null
            || request.resource.data.updatedBy == request.auth.uid
          );

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.relationshipCode
              == resource.data.relationshipCode
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.riskScore is int
          && request.resource.data.riskScore >= 0
          && request.resource.data.riskScore <= 100
          && request.resource.data.trustScore is int
          && request.resource.data.trustScore >= 0
          && request.resource.data.trustScore <= 100
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.accessRevoked == true
          && resource.data.accessLevel == 'none'
          && resource.data.relatedAssetIds.size() == 0
          && resource.data.relatedRightIds.size() == 0
          && resource.data.relatedDocumentIds.size() == 0
          && resource.data.relatedProductIds.size() == 0
          && resource.data.relatedCaseIds.size() == 0
          && resource.data.status != 'active'
          && resource.data.status != 'high_risk'
          && resource.data.status != 'under_review';
    }
    // ============================================================
    // FİKRİ MÜLKİYET — HAK SAHİPLİĞİ KAYITLARI
    // tenantId, marka hesabının Firebase Auth UID değeridir.
    // Hak sahipliği kimliği, tenant ve ilk oluşturma bilgileri
    // güncelleme sırasında değiştirilemez.
    // ============================================================

    match /ip_ownership_records/{ownershipRecordId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.keys().hasAll([
            'tenantId',
            'brandId',
            'assetId',
            'recordCode',
            'ownershipKind',
            'partyType',
            'partyName',
            'partyId',
            'partyExternalId',
            'partyCountryCode',
            'partyRegistrationNumber',
            'partyTaxNumber',
            'partyContactEmail',
            'acquisitionType',
            'status',
            'ownershipPercentage',
            'jurisdictionScope',
            'countryCodes',
            'regionCode',
            'rightId',
            'sourceOwnershipRecordId',
            'previousOwnershipRecordId',
            'nextOwnershipRecordId',
            'agreementNumber',
            'agreementDate',
            'effectiveFrom',
            'effectiveUntil',
            'isExclusive',
            'isPrimaryOwner',
            'isBeneficialOwner',
            'isOwnershipVerified',
            'verificationDate',
            'verifiedBy',
            'documentIds',
            'relationshipIds',
            'transferChainRecordIds',
            'notes',
            'metadata',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])
          && request.resource.data.keys().hasOnly([
            'tenantId',
            'brandId',
            'assetId',
            'recordCode',
            'ownershipKind',
            'partyType',
            'partyName',
            'partyId',
            'partyExternalId',
            'partyCountryCode',
            'partyRegistrationNumber',
            'partyTaxNumber',
            'partyContactEmail',
            'acquisitionType',
            'status',
            'ownershipPercentage',
            'jurisdictionScope',
            'countryCodes',
            'regionCode',
            'rightId',
            'sourceOwnershipRecordId',
            'previousOwnershipRecordId',
            'nextOwnershipRecordId',
            'agreementNumber',
            'agreementDate',
            'effectiveFrom',
            'effectiveUntil',
            'isExclusive',
            'isPrimaryOwner',
            'isBeneficialOwner',
            'isOwnershipVerified',
            'verificationDate',
            'verifiedBy',
            'documentIds',
            'relationshipIds',
            'transferChainRecordIds',
            'notes',
            'metadata',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])

          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.tenantId.size() > 0

          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0

          && request.resource.data.assetId is string
          && request.resource.data.assetId.size() > 0

          && request.resource.data.recordCode is string
          && request.resource.data.recordCode.size() > 0
          && request.resource.data.recordCode.size() <= 100

          && request.resource.data.partyName is string
          && request.resource.data.partyName.size() > 0
          && request.resource.data.partyName.size() <= 300

          && request.resource.data.ownershipKind in [
            'legal_owner',
            'economic_owner',
            'joint_owner',
            'creator',
            'inventor',
            'designer',
            'employee_creation',
            'founder_contribution',
            'contractor_creation',
            'agency_creation',
            'commissioned_work',
            'contract_manufacturing',
            'assignee',
            'assignor',
            'licensor',
            'licensee',
            'beneficial_owner',
            'custodian',
            'other'
          ]

          && request.resource.data.partyType in [
            'person',
            'company',
            'institution',
            'public_body',
            'university',
            'research_organization',
            'partnership',
            'team',
            'unknown'
          ]

          && request.resource.data.acquisitionType in [
            'original_creation',
            'employment',
            'commissioned_work',
            'assignment',
            'license',
            'inheritance',
            'merger',
            'acquisition',
            'court_decision',
            'statutory_transfer',
            'joint_development',
            'other'
          ]

          && request.resource.data.status in [
            'draft',
            'under_review',
            'active',
            'disputed',
            'suspended',
            'transferred',
            'expired',
            'revoked',
            'ended',
            'archived'
          ]

          && request.resource.data.jurisdictionScope in [
            'national',
            'regional',
            'international',
            'contractual',
            'unregistered'
          ]

          && request.resource.data.ownershipPercentage is number
          && request.resource.data.ownershipPercentage >= 0
          && request.resource.data.ownershipPercentage <= 100

          && request.resource.data.countryCodes is list
          && request.resource.data.documentIds is list
          && request.resource.data.relationshipIds is list
          && request.resource.data.transferChainRecordIds is list
          && request.resource.data.metadata is map

          && request.resource.data.isExclusive is bool
          && request.resource.data.isPrimaryOwner is bool
          && request.resource.data.isBeneficialOwner is bool
          && request.resource.data.isOwnershipVerified is bool

          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid

          && request.resource.data.updatedAt == null
          && request.resource.data.updatedBy == null;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid

          && request.resource.data.keys().hasAll([
            'tenantId',
            'brandId',
            'assetId',
            'recordCode',
            'ownershipKind',
            'partyType',
            'partyName',
            'acquisitionType',
            'status',
            'ownershipPercentage',
            'jurisdictionScope',
            'countryCodes',
            'isExclusive',
            'isPrimaryOwner',
            'isBeneficialOwner',
            'isOwnershipVerified',
            'documentIds',
            'relationshipIds',
            'transferChainRecordIds',
            'metadata',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])

          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.assetId == resource.data.assetId
          && request.resource.data.recordCode == resource.data.recordCode
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy

          && request.resource.data.ownershipKind in [
            'legal_owner',
            'economic_owner',
            'joint_owner',
            'creator',
            'inventor',
            'designer',
            'employee_creation',
            'founder_contribution',
            'contractor_creation',
            'agency_creation',
            'commissioned_work',
            'contract_manufacturing',
            'assignee',
            'assignor',
            'licensor',
            'licensee',
            'beneficial_owner',
            'custodian',
            'other'
          ]

          && request.resource.data.partyType in [
            'person',
            'company',
            'institution',
            'public_body',
            'university',
            'research_organization',
            'partnership',
            'team',
            'unknown'
          ]

          && request.resource.data.acquisitionType in [
            'original_creation',
            'employment',
            'commissioned_work',
            'assignment',
            'license',
            'inheritance',
            'merger',
            'acquisition',
            'court_decision',
            'statutory_transfer',
            'joint_development',
            'other'
          ]

          && request.resource.data.status in [
            'draft',
            'under_review',
            'active',
            'disputed',
            'suspended',
            'transferred',
            'expired',
            'revoked',
            'ended',
            'archived'
          ]

          && request.resource.data.jurisdictionScope in [
            'national',
            'regional',
            'international',
            'contractual',
            'unregistered'
          ]

          && request.resource.data.partyName is string
          && request.resource.data.partyName.size() > 0
          && request.resource.data.partyName.size() <= 300

          && request.resource.data.ownershipPercentage is number
          && request.resource.data.ownershipPercentage >= 0
          && request.resource.data.ownershipPercentage <= 100

          && request.resource.data.countryCodes is list
          && request.resource.data.documentIds is list
          && request.resource.data.relationshipIds is list
          && request.resource.data.transferChainRecordIds is list
          && request.resource.data.metadata is map

          && request.resource.data.isExclusive is bool
          && request.resource.data.isPrimaryOwner is bool
          && request.resource.data.isBeneficialOwner is bool
          && request.resource.data.isOwnershipVerified is bool

          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.status == 'draft'
          && resource.data.documentIds.size() == 0
          && resource.data.relationshipIds.size() == 0
          && resource.data.transferChainRecordIds.size() == 0
          && resource.data.sourceOwnershipRecordId == null
          && resource.data.previousOwnershipRecordId == null
          && resource.data.nextOwnershipRecordId == null
          && resource.data.rightId == null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

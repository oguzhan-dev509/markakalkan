rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidRequiredText(value, maxLength) {
      return value is string
          && value.size() > 0
          && value.size() <= maxLength;
    }

    function isValidOptionalText(value, maxLength) {
      return value == null
          || (value is string && value.size() <= maxLength);
    }

   match /brandApplications/{applicationId} {
  allow create: if
      request.auth != null
      && request.auth.token.email != null
      && request.resource.data.keys().hasAll([
        'applicantUid',
        'applicantEmail',
        'companyName',
        'brandName',
        'businessType',
        'sector',
        'authorizedPerson',
        'email',
        'phone',
        'taxNumber',
        'website',
        'problemDescription',
        'status',
        'createdAt'
      ])
      && request.resource.data.keys().hasOnly([
        'applicantUid',
        'applicantEmail',
        'companyName',
        'brandName',
        'businessType',
        'sector',
        'authorizedPerson',
        'email',
        'phone',
        'taxNumber',
        'website',
        'problemDescription',
        'status',
        'createdAt'
      ])
      && request.resource.data.applicantUid == request.auth.uid
      && request.resource.data.applicantEmail == request.auth.token.email
      && request.resource.data.email == request.auth.token.email
      && isValidRequiredText(
        request.resource.data.applicantUid,
        160
      )
      && isValidRequiredText(
        request.resource.data.applicantEmail,
        180
      )
      && request.resource.data.applicantEmail.matches(
        '^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$'
      )
      && isValidRequiredText(
        request.resource.data.companyName,
        180
      )
      && isValidRequiredText(
        request.resource.data.brandName,
        120
      )
      && isValidRequiredText(
        request.resource.data.businessType,
        60
      )
      && isValidRequiredText(
        request.resource.data.sector,
        80
      )
      && isValidRequiredText(
        request.resource.data.authorizedPerson,
        120
      )
      && isValidRequiredText(
        request.resource.data.email,
        180
      )
      && request.resource.data.email.matches(
        '^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$'
      )
      && isValidRequiredText(
        request.resource.data.phone,
        40
      )
      && isValidRequiredText(
        request.resource.data.taxNumber,
        30
      )
      && isValidOptionalText(
        request.resource.data.website,
        300
      )
      && isValidRequiredText(
        request.resource.data.problemDescription,
        2000
      )
      && request.resource.data.status == 'pending'
      && request.resource.data.createdAt == request.time;

  allow read, update, delete: if false;
}
match /brands/{brandUid}/products/{productId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'name',
        'brandName',
        'sku',
        'category',
        'description',
        'isActive',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'name',
        'brandName',
        'sku',
        'category',
        'description',
        'isActive',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() >= 2
      && request.resource.data.name.size() <= 160
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.sku is string
      && request.resource.data.sku.size() <= 80
      && request.resource.data.category is string
      && request.resource.data.category.size() >= 2
      && request.resource.data.category.size() <= 100
      && request.resource.data.description is string
      && request.resource.data.description.size() <= 2000
      && request.resource.data.isActive is bool
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  allow update: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid;
}
match /brands/{brandUid}/productionBatches/{batchId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'productId',
        'productName',
        'batchNumber',
        'productionType',
        'authorizedQuantity',
        'defectQuantity',
        'shippedQuantity',
        'productionDate',
        'notes',
        'status',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'productId',
        'productName',
        'batchNumber',
        'productionType',
        'authorizedQuantity',
        'defectQuantity',
        'shippedQuantity',
        'productionDate',
        'notes',
        'status',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.productId is string
      && request.resource.data.productId.size() > 0
      && request.resource.data.productId.size() <= 160
      && request.resource.data.productName is string
      && request.resource.data.productName.size() > 0
      && request.resource.data.productName.size() <= 160
      && request.resource.data.batchNumber is string
      && request.resource.data.batchNumber.size() >= 2
      && request.resource.data.batchNumber.size() <= 100
      && request.resource.data.productionType is string
      && request.resource.data.productionType in [
        'Kendi üretim',
        'Fason üretim',
        'İthalat'
      ]
      && request.resource.data.authorizedQuantity is int
      && request.resource.data.authorizedQuantity > 0
      && request.resource.data.defectQuantity is int
      && request.resource.data.defectQuantity >= 0
      && request.resource.data.shippedQuantity is int
      && request.resource.data.shippedQuantity >= 0
      && request.resource.data.defectQuantity
          + request.resource.data.shippedQuantity
          <= request.resource.data.authorizedQuantity
      && request.resource.data.productionDate is timestamp
      && request.resource.data.notes is string
      && request.resource.data.notes.size() <= 2000
      && request.resource.data.status in [
        'planned',
        'in_production',
        'completed',
        'cancelled'
      ]
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  allow update: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.keys().hasOnly([
        'productId',
        'productName',
        'batchNumber',
        'productionType',
        'authorizedQuantity',
        'defectQuantity',
        'shippedQuantity',
        'productionDate',
        'notes',
        'status',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid;
}
match /brands/{brandUid}/digitalDetectiveTasks/{taskId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'taskName',
        'brandName',
        'productName',
        'categoryId',
        'subcategory',
        'violationIds',
        'sources',
        'searchTerms',
        'excludedTerms',
        'countries',
        'cities',
        'minimumPrice',
        'maximumPrice',
        'currency',
        'frequency',
        'riskLevel',
        'startDate',
        'endDate',
        'status',
        'ownerUid',
        'ownerEmail',
        'resultCount',
        'processedCount',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'taskName',
        'brandName',
        'productName',
        'categoryId',
        'subcategory',
        'violationIds',
        'sources',
        'searchTerms',
        'excludedTerms',
        'countries',
        'cities',
        'minimumPrice',
        'maximumPrice',
        'currency',
        'frequency',
        'riskLevel',
        'startDate',
        'endDate',
        'status',
        'ownerUid',
        'ownerEmail',
        'resultCount',
        'processedCount',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.taskName is string
      && request.resource.data.taskName.size() >= 2
      && request.resource.data.taskName.size() <= 180
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 160
      && request.resource.data.productName is string
      && request.resource.data.productName.size() >= 2
      && request.resource.data.productName.size() <= 240
      && request.resource.data.categoryId is string
      && request.resource.data.categoryId.size() > 0
      && (
        request.resource.data.subcategory == null
        || request.resource.data.subcategory is string
      )
      && request.resource.data.violationIds is list
      && request.resource.data.violationIds.size() > 0
      && request.resource.data.sources is list
      && request.resource.data.sources.size() > 0
      && request.resource.data.searchTerms is list
      && request.resource.data.excludedTerms is list
      && request.resource.data.countries is list
      && request.resource.data.countries.size() > 0
      && request.resource.data.cities is list
      && (
        request.resource.data.minimumPrice == null
        || request.resource.data.minimumPrice is number
      )
      && (
        request.resource.data.maximumPrice == null
        || request.resource.data.maximumPrice is number
      )
      && request.resource.data.currency is string
      && request.resource.data.frequency is string
      && request.resource.data.riskLevel is string
      && request.resource.data.startDate is timestamp
      && request.resource.data.endDate is timestamp
      && request.resource.data.endDate >= request.resource.data.startDate
      && request.resource.data.status == 'queued'
      && (
        request.resource.data.ownerEmail == null
        || request.resource.data.ownerEmail is string
      )
      && request.resource.data.resultCount == 0
      && request.resource.data.processedCount == 0
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  // Görev sonuçlarını ileride n8n/Admin SDK güncelleyecek.
  allow update: if false;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid;

  match /findings/{findingId} {
    // Marka hesabı yalnız kendi Dijital Dedektif bulgularını okuyabilir.
    allow read: if request.auth != null
        && request.auth.uid == brandUid;

    // Bulgular yalnız güvenilir sunucu servisleriyle yazılır.
    allow create, update, delete: if false;
  }
}

match /brands/{brandUid}/aiFieldOperations/{operationId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'title',
        'objective',
        'status',
        'priority',
        'createdAt',
        'updatedAt',
        'currentAgentId',
        'requiresHumanApproval'
      ])
      && request.resource.data.keys().hasOnly([
        'title',
        'objective',
        'status',
        'priority',
        'createdAt',
        'updatedAt',
        'currentAgentId',
        'requiresHumanApproval'
      ])
      && request.resource.data.title is string
      && request.resource.data.title.size() >= 2
      && request.resource.data.title.size() <= 180
      && request.resource.data.objective is string
      && request.resource.data.objective.size() >= 3
      && request.resource.data.objective.size() <= 2000
      && request.resource.data.status == 'queued'
      && request.resource.data.priority in [
        'low',
        'normal',
        'high',
        'critical'
      ]
      && request.resource.data.currentAgentId == 'task_planner'
      && request.resource.data.requiresHumanApproval == true
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  allow update: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'title',
        'objective',
        'status',
        'priority',
        'createdAt',
        'updatedAt',
        'currentAgentId',
        'requiresHumanApproval'
      ])
      && request.resource.data.keys().hasOnly([
        'title',
        'objective',
        'status',
        'priority',
        'createdAt',
        'updatedAt',
        'currentAgentId',
        'requiresHumanApproval'
      ])
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'updatedAt',
        'currentAgentId'
      ])
      && request.resource.data.title == resource.data.title
      && request.resource.data.objective == resource.data.objective
      && request.resource.data.priority == resource.data.priority
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.requiresHumanApproval
          == resource.data.requiresHumanApproval
      && request.resource.data.status in [
        'draft',
        'queued',
        'running',
        'waiting_human_approval',
        'completed',
        'failed',
        'cancelled'
      ]
      && request.resource.data.currentAgentId in [
        'task_planner',
        'digital_field_scanner',
        'page_change_monitor',
        'visual_matcher',
        'text_language_analyst',
        'seller_entity_resolver',
        'network_analyst',
        'price_anomaly_analyst',
        'evidence_custodian',
        'risk_intervention_analyst',
        'reporting_agent',
        'human_expert_gate'
      ]
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid;

  match /agentTasks/{taskId} {
    allow read: if request.auth != null
        && request.auth.uid == brandUid;

    allow create: if request.auth != null
        && request.auth.uid == brandUid
        && request.resource.data.keys().hasAll([
          'agentId',
          'agentName',
          'agentOrder',
          'status',
          'input',
          'output',
          'startedAt',
          'completedAt',
          'errorMessage',
          'handoffToAgentId'
        ])
        && request.resource.data.keys().hasOnly([
          'agentId',
          'agentName',
          'agentOrder',
          'status',
          'input',
          'output',
          'startedAt',
          'completedAt',
          'errorMessage',
          'handoffToAgentId'
        ])
        && request.resource.data.agentId == taskId
        && request.resource.data.agentId in [
          'task_planner',
          'digital_field_scanner',
          'page_change_monitor',
          'visual_matcher',
          'text_language_analyst',
          'seller_entity_resolver',
          'network_analyst',
          'price_anomaly_analyst',
          'evidence_custodian',
          'risk_intervention_analyst',
          'reporting_agent',
          'human_expert_gate'
        ]
        && request.resource.data.agentName is string
        && request.resource.data.agentName.size() >= 2
        && request.resource.data.agentName.size() <= 160
        && request.resource.data.agentOrder is int
        && request.resource.data.agentOrder >= 1
        && request.resource.data.agentOrder <= 12
        && request.resource.data.status in [
          'pending',
          'queued'
        ]
        && (
          (
            request.resource.data.agentId == 'task_planner'
            && request.resource.data.status == 'queued'
          )
          ||
          (
            request.resource.data.agentId != 'task_planner'
            && request.resource.data.status == 'pending'
          )
        )
        && request.resource.data.input is map
        && request.resource.data.output is map
        && request.resource.data.startedAt == null
        && request.resource.data.completedAt == null
        && request.resource.data.errorMessage is string
        && request.resource.data.errorMessage.size() == 0
        && request.resource.data.handoffToAgentId is string
        && (
          request.resource.data.handoffToAgentId == ''
          || request.resource.data.handoffToAgentId in [
            'task_planner',
            'digital_field_scanner',
            'page_change_monitor',
            'visual_matcher',
            'text_language_analyst',
            'seller_entity_resolver',
            'network_analyst',
            'price_anomaly_analyst',
            'evidence_custodian',
            'risk_intervention_analyst',
            'reporting_agent',
            'human_expert_gate'
          ]
        );

    allow update: if request.auth != null
        && request.auth.uid == brandUid
        && request.resource.data.keys().hasAll([
          'agentId',
          'agentName',
          'agentOrder',
          'status',
          'input',
          'output',
          'startedAt',
          'completedAt',
          'errorMessage',
          'handoffToAgentId'
        ])
        && request.resource.data.keys().hasOnly([
          'agentId',
          'agentName',
          'agentOrder',
          'status',
          'input',
          'output',
          'startedAt',
          'completedAt',
          'errorMessage',
          'handoffToAgentId'
        ])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'output',
          'startedAt',
          'completedAt',
          'errorMessage',
          'handoffToAgentId'
        ])
        && request.resource.data.agentId == resource.data.agentId
        && request.resource.data.agentName == resource.data.agentName
        && request.resource.data.agentOrder == resource.data.agentOrder
        && request.resource.data.input == resource.data.input
        && request.resource.data.status in [
          'pending',
          'queued',
          'running',
          'completed',
          'failed',
          'skipped',
          'waiting_handoff',
          'waiting_human_approval'
        ]
        && request.resource.data.output is map
        && (
          request.resource.data.startedAt == null
          || request.resource.data.startedAt is timestamp
        )
        && (
          request.resource.data.completedAt == null
          || request.resource.data.completedAt is timestamp
        )
        && request.resource.data.errorMessage is string
        && request.resource.data.errorMessage.size() <= 2000
        && request.resource.data.handoffToAgentId is string
        && (
          request.resource.data.handoffToAgentId == ''
          || request.resource.data.handoffToAgentId in [
            'task_planner',
            'digital_field_scanner',
            'page_change_monitor',
            'visual_matcher',
            'text_language_analyst',
            'seller_entity_resolver',
            'network_analyst',
            'price_anomaly_analyst',
            'evidence_custodian',
            'risk_intervention_analyst',
            'reporting_agent',
            'human_expert_gate'
          ]
        );

    allow delete: if request.auth != null
        && request.auth.uid == brandUid;
  }
}
match /productCodes/{codeId} {
  // Tüketici yalnız bildiği tekil kodu doğrudan sorgulayabilir.
  // Tüm kod koleksiyonu herkese açık şekilde listelenemez.
  allow read: if request.auth != null
    && resource.data.ownerUid == request.auth.uid;

  allow create: if request.auth != null
      && request.resource.data.keys().hasAll([
        'publicCode',
        'ownerUid',
        'brandName',
        'productId',
        'productName',
        'batchId',
        'batchNumber',
        'status',
        'scanCount',
        'firstVerifiedAt',
        'lastVerifiedAt',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'publicCode',
        'ownerUid',
        'brandName',
        'productId',
        'productName',
        'batchId',
        'batchNumber',
        'status',
        'scanCount',
        'firstVerifiedAt',
        'lastVerifiedAt',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.publicCode == codeId
      && request.resource.data.publicCode is string
      && request.resource.data.publicCode.size() >= 10
      && request.resource.data.publicCode.size() <= 80
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.productId is string
      && request.resource.data.productId.size() > 0
      && request.resource.data.productName is string
      && request.resource.data.productName.size() > 0
      && request.resource.data.productName.size() <= 160
      && request.resource.data.batchId is string
      && request.resource.data.batchId.size() > 0
      && request.resource.data.batchNumber is string
      && request.resource.data.batchNumber.size() >= 2
      && request.resource.data.batchNumber.size() <= 100
      && request.resource.data.status == 'active'
      && request.resource.data.scanCount == 0
      && request.resource.data.firstVerifiedAt == null
      && request.resource.data.lastVerifiedAt == null
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time
      && exists(
        /databases/$(database)/documents/brands/$(request.auth.uid)/products/$(request.resource.data.productId)
      )
      && exists(
        /databases/$(database)/documents/brands/$(request.auth.uid)/productionBatches/$(request.resource.data.batchId)
      )
      && get(
        /databases/$(database)/documents/brands/$(request.auth.uid)/productionBatches/$(request.resource.data.batchId)
      ).data.productId == request.resource.data.productId;

  // Marka sahibi yalnız kodun durumunu değiştirebilir.
  // Tarama sayaçları ileride güvenli sunucu fonksiyonuyla güncellenecek.
  allow update: if request.auth != null
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == resource.data.ownerUid
      && request.resource.data.publicCode == resource.data.publicCode
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'updatedAt'
      ])
      && request.resource.data.status in [
        'active',
        'blocked',
        'revoked'
      ]
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && resource.data.ownerUid == request.auth.uid;
}
match /publicProductCodes/{codeId} {
  allow get: if true;
  allow list: if false;

  allow create: if request.auth != null
      && request.resource.data.keys().hasAll([
        'publicCode',
        'brandName',
        'productName',
        'batchNumber',
        'status',
        'createdAt'
      ])
      && request.resource.data.keys().hasOnly([
        'publicCode',
        'brandName',
        'productName',
        'batchNumber',
        'status',
        'createdAt'
      ])
      && request.resource.data.publicCode == codeId
      && request.resource.data.publicCode is string
      && request.resource.data.publicCode.size() >= 10
      && request.resource.data.publicCode.size() <= 80
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.productName is string
      && request.resource.data.productName.size() >= 2
      && request.resource.data.productName.size() <= 160
      && request.resource.data.batchNumber is string
      && request.resource.data.batchNumber.size() >= 2
      && request.resource.data.batchNumber.size() <= 100
      && request.resource.data.status == 'active'
      && request.resource.data.createdAt == request.time

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.ownerUid == request.auth.uid

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.publicCode == request.resource.data.publicCode

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.brandName == request.resource.data.brandName

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.productName == request.resource.data.productName

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.batchNumber == request.resource.data.batchNumber

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.status == request.resource.data.status;

  allow update, delete: if false;
}

    // ============================================================
    // DİJİTAL PAZAR İZLEME
    // tenantId, mevcut marka hesabının Firebase Auth UID değeridir.
    // ============================================================

    match /monitoring_page_snapshots/{snapshotId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.tenantId.size() > 0
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && request.resource.data.sourceId is string
          && request.resource.data.sourceId.size() > 0
          && request.resource.data.pageId is string
          && request.resource.data.pageId.size() > 0
          && request.resource.data.crawlRunId is string
          && request.resource.data.crawlRunId.size() > 0
          && request.resource.data.capturedAt is timestamp
          && request.resource.data.createdAt is timestamp;

      // Snapshot kayıtları tarihsel delildir; değiştirilemez ve silinemez.
      allow update, delete: if false;
    }

    match /monitoring_events/{eventId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.brandId is string
          && request.resource.data.sourceId is string
          && request.resource.data.pageId is string
          && request.resource.data.previousSnapshotId is string
          && request.resource.data.currentSnapshotId is string
          && request.resource.data.eventType is string
          && request.resource.data.eventCategory is string
          && request.resource.data.severity in [
            'low',
            'medium',
            'high',
            'critical'
          ]
          && request.resource.data.status is string
          && request.resource.data.detectedAt is timestamp
          && request.resource.data.createdAt is timestamp;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.sourceId == resource.data.sourceId
          && request.resource.data.pageId == resource.data.pageId
          && request.resource.data.previousSnapshotId
              == resource.data.previousSnapshotId
          && request.resource.data.currentSnapshotId
              == resource.data.currentSnapshotId
          && request.resource.data.eventType == resource.data.eventType
          && request.resource.data.eventCategory
              == resource.data.eventCategory
          && request.resource.data.detectedAt == resource.data.detectedAt
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'reviewedAt'
          ])
          && request.resource.data.status is string
          && request.resource.data.reviewedAt is timestamp;

      allow delete: if false;
    }

    match /monitoring_signal_rules/{ruleId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 180
          && request.resource.data.eventTypes is list
          && request.resource.data.sourceIds is list
          && request.resource.data.conditions is list
          && request.resource.data.signalLevel in [
            'low',
            'medium',
            'high',
            'critical'
          ]
          && request.resource.data.status is string
          && request.resource.data.priority in [
            'low',
            'normal',
            'high',
            'critical'
          ]
          && request.resource.data.stopOnMatch is bool
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy is string
          && request.resource.data.createdBy.size() > 0;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'brandId',
            'name',
            'description',
            'eventTypes',
            'sourceIds',
            'conditions',
            'signalLevel',
            'status',
            'priority',
            'signalTitleTemplate',
            'signalSummaryTemplate',
            'stopOnMatch',
            'updatedAt',
            'updatedBy'
          ])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 180
          && request.resource.data.eventTypes is list
          && request.resource.data.sourceIds is list
          && request.resource.data.conditions is list
          && request.resource.data.signalLevel in [
            'low',
            'medium',
            'high',
            'critical'
          ]
          && request.resource.data.status is string
          && request.resource.data.priority in [
            'low',
            'normal',
            'high',
            'critical'
          ]
          && request.resource.data.stopOnMatch is bool
          && request.resource.data.updatedAt is timestamp;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid;
    }

    match /monitoring_signals/{signalId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.brandId is string
          && request.resource.data.sourceId is string
          && request.resource.data.pageId is string
          && request.resource.data.eventId is string
          && request.resource.data.eventId.size() > 0
          && request.resource.data.ruleId is string
          && request.resource.data.ruleId.size() > 0
          && request.resource.data.signalLevel in [
            'low',
            'medium',
            'high',
            'critical'
          ]
          && request.resource.data.status is string
          && request.resource.data.forwardingStatus is string
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.summary is string
          && request.resource.data.detectedAt is timestamp
          && request.resource.data.createdAt is timestamp;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.sourceId == resource.data.sourceId
          && request.resource.data.pageId == resource.data.pageId
          && request.resource.data.eventId == resource.data.eventId
          && request.resource.data.ruleId == resource.data.ruleId
          && request.resource.data.detectedAt == resource.data.detectedAt
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'reviewedAt',
            'reviewedBy',
            'forwardingStatus',
            'forwardedAt',
            'forwardingError',
            'resolvedAt',
            'resolvedBy',
            'resolutionNote',
            'updatedAt',
            'updatedBy'
          ]);

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}




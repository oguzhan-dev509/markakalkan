match /ip_trade_secret_components/{recordId} {
allow get, list: if request.auth != null
&& resource.data.tenantId == request.auth.uid;
allow create: if request.auth != null
&& request.resource.data.keys().hasAll(ipTsComponentFields())
&& request.resource.data.keys().hasOnly(ipTsComponentFields())
&& request.resource.data.tenantId == request.auth.uid
&& request.resource.data.brandId is string
&& request.resource.data.brandId.size() > 0
&& request.resource.data.componentCode is string
&& request.resource.data.componentCode.size() > 0
&& request.resource.data.componentCode.size() <= 160
&& request.resource.data.tradeSecretId is string
&& request.resource.data.tradeSecretId.size() > 0
&& exists(
/databases/$(database)/documents/ip_trade_secrets/$(
request.resource.data.tradeSecretId
)
)
&& get(
/databases/$(database)/documents/ip_trade_secrets/$(
request.resource.data.tradeSecretId
)
).data.tenantId == request.auth.uid
&& get(
/databases/$(database)/documents/ip_trade_secrets/$(
request.resource.data.tradeSecretId
)
).data.brandId == request.resource.data.brandId          && !request.resource.data.keys().hasAny([
'formulaContent',
'recipeContent',
'secretContent',
'plaintextSecret',
'rawFormula',
'rawRecipe',
'sourceCodeContent',
'algorithmContent'
])
&& (
!request.resource.data.keys().hasAny(['metadata'])
|| request.resource.data.metadata == null
|| (
request.resource.data.metadata is map
&& !request.resource.data.metadata.keys().hasAny([
'formulaContent',
'recipeContent',
'secretContent',
'plaintextSecret',
'rawFormula',
'rawRecipe',
'sourceCodeContent',
'algorithmContent'
])
)
)
&& request.resource.data.createdAt == request.time
&& request.resource.data.createdBy == request.auth.uid
&& request.resource.data.updatedAt == request.time
&& (
request.resource.data.updatedBy == null
|| request.resource.data.updatedBy == request.auth.uid
);
allow update: if request.auth != null
&& resource.data.tenantId == request.auth.uid
&& request.resource.data.tenantId == resource.data.tenantId
&& request.resource.data.brandId == resource.data.brandId
&& request.resource.data.tradeSecretId == resource.data.tradeSecretId
&& request.resource.data.componentCode == resource.data.componentCode
&& request.resource.data.createdAt == resource.data.createdAt
&& request.resource.data.createdBy == resource.data.createdBy
&& request.resource.data.keys().hasOnly(ipTsComponentFields())
&& request.resource.data.componentCode is string
&& request.resource.data.componentCode.size() > 0
&& request.resource.data.componentCode.size() <= 160
&& !request.resource.data.keys().hasAny([
'formulaContent',
'recipeContent',
'secretContent',
'plaintextSecret',
'rawFormula',
'rawRecipe',
'sourceCodeContent',
'algorithmContent'

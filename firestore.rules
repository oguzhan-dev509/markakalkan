rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidRequiredText(value, maxLength) {
      return value is string
          && value.size() > 0
          && value.size() <= maxLength;
    }

    function isValidOptionalText(value, maxLength) {
      return value == null
          || (value is string && value.size() <= maxLength);
    }

    match /brandApplications/{applicationId} {
      allow create: if
          request.resource.data.keys().hasAll([
            'companyName',
            'brandName',
            'businessType',
            'sector',
            'authorizedPerson',
            'email',
            'phone',
            'taxNumber',
            'website',
            'problemDescription',
            'status',
            'createdAt'
          ])
          && request.resource.data.keys().hasOnly([
            'companyName',
            'brandName',
            'businessType',
            'sector',
            'authorizedPerson',
            'email',
            'phone',
            'taxNumber',
            'website',
            'problemDescription',
            'status',
            'createdAt'
          ])
          && isValidRequiredText(
            request.resource.data.companyName,
            180
          )
          && isValidRequiredText(
            request.resource.data.brandName,
            120
          )
          && isValidRequiredText(
            request.resource.data.businessType,
            60
          )
          && isValidRequiredText(
            request.resource.data.sector,
            80
          )
          && isValidRequiredText(
            request.resource.data.authorizedPerson,
            120
          )
          && isValidRequiredText(
            request.resource.data.email,
            180
          )
          && request.resource.data.email.matches(
            '^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$'
          )
          && isValidRequiredText(
            request.resource.data.phone,
            40
          )
          && isValidRequiredText(
            request.resource.data.taxNumber,
            30
          )
          && isValidOptionalText(
            request.resource.data.website,
            300
          )
          && isValidRequiredText(
            request.resource.data.problemDescription,
            2000
          )
          && request.resource.data.status == 'pending'
          && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }
match /brands/{brandUid}/products/{productId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'name',
        'brandName',
        'sku',
        'category',
        'description',
        'isActive',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'name',
        'brandName',
        'sku',
        'category',
        'description',
        'isActive',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() >= 2
      && request.resource.data.name.size() <= 160
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.sku is string
      && request.resource.data.sku.size() <= 80
      && request.resource.data.category is string
      && request.resource.data.category.size() >= 2
      && request.resource.data.category.size() <= 100
      && request.resource.data.description is string
      && request.resource.data.description.size() <= 2000
      && request.resource.data.isActive is bool
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  allow update: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid;
}
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
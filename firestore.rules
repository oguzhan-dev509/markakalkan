          && request.resource.data.operationalProtectionScore is int
          && request.resource.data.operationalProtectionScore >= 0
          && request.resource.data.operationalProtectionScore <= 100
          && request.resource.data.secretSecurityScore is int
          && request.resource.data.secretSecurityScore >= 0
          && request.resource.data.secretSecurityScore <= 100
          && !request.resource.data.keys().hasAny([
            'formulaContent',
            'recipeContent',
            'secretContent',
            'plaintextSecret',
            'rawFormula',
            'rawRecipe',
            'sourceCodeContent',
            'algorithmContent'
          ])
          && !request.resource.data.metadata.keys().hasAny([
            'formulaContent',
            'recipeContent',
            'secretContent',
            'plaintextSecret',
            'rawFormula',
            'rawRecipe',
            'sourceCodeContent',
            'algorithmContent'
          ])
          && (
            request.resource.data.protectionMode != 'encrypted_vault'
            || (
              request.resource.data.encryptedSecretReference is string
              && request.resource.data.encryptedSecretReference.size() > 0
            )
          )
          && (
            request.resource.data.protectionMode
                != 'external_secure_system'
            || (
              request.resource.data.externalSecureSystemReference is string
              && request.resource.data.externalSecureSystemReference.size() > 0
            )
          )
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && (
            request.resource.data.updatedBy == null
            || request.resource.data.updatedBy == request.auth.uid
          );

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.secretCode == resource.data.secretCode

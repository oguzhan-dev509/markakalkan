    // ============================================================
    // FASON ÜRETİM VE TEDARİK GÜVENLİĞİ — PARTNER SİCİLİ
    // tenantId, marka hesabının Firebase Auth UID değeridir.
    // Partner kodu, tenant ve ilk oluşturma bilgileri değiştirilemez.
    // ============================================================

    // ============================================================
    // SUPPLY SECURITY ORTAK KURAL FONKSİYONLARI
    // ============================================================

    function ssPartnerFields() {
      return [
        'tenantId',
        'brandId',
        'partnerCode',
        'partnerCodeNormalized',
        'legalName',
        'tradeName',
        'taxNumber',
        'registrationNumber',
        'roles',
        'status',
        'verificationStatus',
        'riskLevel',
        'trustScore',
        'countryCode',
        'city',
        'region',
        'address',
        'website',
        'contactPersonName',
        'email',
        'phone',
        'isCriticalPartner',
        'contractManufacturingAuthorized',
        'subcontractingAllowed',
        'hasNda',
        'auditRequired',
        'lastAuditAt',
        'nextAuditAt',
        'certificateDocumentIds',
        'relatedFacilityIds',
        'relatedProductIds',
        'productCategoryCodes',
        'notes',
        'archiveReason',
        'archivedAt',
        'metadata',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy'
      ];
    }

    function ssFacilityFields() {
      return [
        'tenantId',
        'brandId',
        'partnerId',
        'facilityCode',
        'facilityCodeNormalized',
        'name',
        'facilityType',
        'status',
        'verificationStatus',
        'riskLevel',
        'authorizationStatus',
        'parentFacilityId',
        'countryCode',
        'city',
        'region',
        'address',
        'latitude',
        'longitude',
        'monthlyCapacity',
        'capacityUnit',
        'shiftCodes',
        'relatedProductIds',
        'productCategoryCodes',
        'certificateDocumentIds',
        'auditDocumentIds',
        'isPrimaryFacility',
        'isCriticalFacility',
        'productionAuthorized',
        'storageAuthorized',
        'packagingAuthorized',
        'labelPrintingAuthorized',
        'destructionAuthorized',
        'subcontractingObserved',
        'suspiciousNightShiftObserved',
        'capacityMismatchObserved',
        'unregisteredShipmentObserved',
        'auditRequired',
        'lastAuditAt',
        'nextAuditAt',
        'lastVerifiedAt',
        'riskReason',
        'notes',
        'archiveReason',
        'archivedAt',
        'metadata',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy'
      ];
    }

    function ssMetadataIsSafe() {
      return request.resource.data.metadata is map
          && !request.resource.data.keys().hasAny([
            'password',
            'credential',
            'accessToken',
            'apiKey',
            'privateKey',
            'formulaContent',
            'recipeContent',
            'secretContent',
            'plaintextSecret',
            'rawFormula',
            'rawRecipe'
          ])
          && !request.resource.data.metadata.keys().hasAny([
            'password',
            'passwd',
            'secret',
            'token',
            'credential',
            'apiKey',
            'api_key',
            'accessKey',
            'access_key',
            'privateKey',
            'private_key',
            'formula',
            'formulaContent',
            'recipe',
            'recipeContent',
            'reçete',
            'formül'
          ]);
    }

    function ssArchiveIsValid() {
      return request.resource.data.status != 'archived'
          || (
            request.resource.data.archiveReason is string
            && request.resource.data.archiveReason.size() > 0
            && request.resource.data.archiveReason.size() <= 2000
            && request.resource.data.archivedAt is timestamp
          );
    }

    function ssAuditDatesAreValid() {
      return (
            request.resource.data.lastAuditAt == null
            || request.resource.data.lastAuditAt is timestamp
          )
          && (
            request.resource.data.nextAuditAt == null
            || request.resource.data.nextAuditAt is timestamp
          )
          && (
            request.resource.data.lastAuditAt == null
            || request.resource.data.nextAuditAt == null
            || request.resource.data.nextAuditAt
                >= request.resource.data.lastAuditAt
          );
    }
    function ssCommonIsValid() {
      return request.resource.data.tenantId is string
          && request.resource.data.tenantId.size() > 0
          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0
          && (request.resource.data.verificationStatus is string && request.resource.data.verificationStatus.matches('^(?:unverified|documents_pending|under_review|verified|rejected|expired)$'))
          && mkIsSignalRiskLevel(request.resource.data.riskLevel)
          && request.resource.data.auditRequired is bool
          && request.resource.data.certificateDocumentIds is list
          && request.resource.data.relatedProductIds is list
          && request.resource.data.productCategoryCodes is list
          && ssMetadataIsSafe()
          && ssAuditDatesAreValid()
          && ssArchiveIsValid()
          && (
            request.resource.data.riskLevel != 'critical'
            || request.resource.data.auditRequired == true
          );
    }
    function ssPartnerIsValid() {
      return request.resource.data.keys().hasOnly(ssPartnerFields())
          && request.resource.data.keys().size() == 40
          && ssCommonIsValid()
          && isValidRequiredText(
            request.resource.data.partnerCode,
            100
          )
          && isValidRequiredText(
            request.resource.data.partnerCodeNormalized,
            100
          )
          && isValidRequiredText(
            request.resource.data.legalName,
            300
          )
          && isValidOptionalText(
            request.resource.data.tradeName,
            300
          )
          && isValidOptionalText(
            request.resource.data.taxNumber,
            80
          )
          && isValidOptionalText(
            request.resource.data.registrationNumber,
            120
          )
          && request.resource.data.roles is list
          && request.resource.data.roles.size() <= 10
          && request.resource.data.roles.hasOnly([
            'manufacturer',
            'contract_manufacturer',
            'raw_material_supplier',
            'packaging_supplier',
            'label_printer',
            'logistics_provider',
            'warehouse_operator',
            'subcontractor',
            'destruction_provider',
            'quality_laboratory'
          ])
          && (request.resource.data.status is string && request.resource.data.status.matches('^(?:draft|pending_verification|active|suspended|blocked|terminated|archived)$'))
          && request.resource.data.trustScore is int
          && request.resource.data.trustScore >= 0
          && request.resource.data.trustScore <= 100
          && isValidOptionalText(
            request.resource.data.countryCode,
            8
          )
          && isValidOptionalText(
            request.resource.data.city,
            160
          )
          && isValidOptionalText(
            request.resource.data.region,
            160
          )
          && isValidOptionalText(
            request.resource.data.address,
            2000
          )
          && isValidOptionalText(
            request.resource.data.website,
            500
          )
          && isValidOptionalText(
            request.resource.data.contactPersonName,
            200
          )
          && isValidOptionalText(
            request.resource.data.email,
            200
          )
          && isValidOptionalText(
            request.resource.data.phone,
            80
          )
          && request.resource.data.isCriticalPartner is bool
          && request.resource.data.contractManufacturingAuthorized is bool
          && request.resource.data.subcontractingAllowed is bool
          && request.resource.data.hasNda is bool
          && request.resource.data.relatedFacilityIds is list
          && request.resource.data.certificateDocumentIds.size() <= 500
          && request.resource.data.relatedFacilityIds.size() <= 500
          && request.resource.data.relatedProductIds.size() <= 500
          && request.resource.data.productCategoryCodes.size() <= 500
          && isValidOptionalText(
            request.resource.data.notes,
            5000
          )
          && isValidOptionalText(
            request.resource.data.archiveReason,
            2000
          )
          && (
            request.resource.data.archivedAt == null
            || request.resource.data.archivedAt is timestamp
          )
          && (
            request.resource.data.status != 'active'
            || request.resource.data.roles.size() > 0
          )
          && (
            request.resource.data.contractManufacturingAuthorized == false
            || request.resource.data.roles.hasAny([
              'manufacturer',
              'contract_manufacturer'
            ])
          )
          && (
            request.resource.data.subcontractingAllowed == false
            || request.resource.data.roles.hasAny([
              'manufacturer',
              'contract_manufacturer',
              'subcontractor'
            ])
          );
    }
    function ssFacilityIsValid() {
      return request.resource.data.keys().hasOnly(ssFacilityFields())
          && request.resource.data.keys().size() == 49
          && ssCommonIsValid()
          && request.resource.data.partnerId is string
          && request.resource.data.partnerId.size() > 0
          && isValidRequiredText(
            request.resource.data.facilityCode,
            100
          )
          && isValidRequiredText(
            request.resource.data.facilityCodeNormalized,
            100
          )
          && isValidRequiredText(
            request.resource.data.name,
            300
          )
          && (request.resource.data.facilityType is string && request.resource.data.facilityType.matches('^(?:factory|contract_manufacturing_plant|production_line|packaging_plant|label_printing_site|raw_material_warehouse|finished_goods_warehouse|distribution_center|destruction_facility|quality_laboratory|suspected_unauthorized_site)$'))
          && (request.resource.data.status is string && request.resource.data.status.matches('^(?:draft|pending_verification|active|suspended|blocked|closed|archived)$'))
          && (request.resource.data.authorizationStatus is string && request.resource.data.authorizationStatus.matches('^(?:not_applicable|unauthorized|pending|authorized|restricted|revoked)$'))
          && request.resource.data.shiftCodes is list
          && request.resource.data.shiftCodes.hasOnly([
            'day',
            'evening',
            'night',
            'weekend',
            'custom'
          ])
          && request.resource.data.auditDocumentIds is list
          && request.resource.data.isPrimaryFacility is bool
          && request.resource.data.isCriticalFacility is bool
          && request.resource.data.productionAuthorized is bool
          && request.resource.data.storageAuthorized is bool
          && request.resource.data.packagingAuthorized is bool
          && request.resource.data.labelPrintingAuthorized is bool
          && request.resource.data.destructionAuthorized is bool
          && request.resource.data.subcontractingObserved is bool
          && request.resource.data.suspiciousNightShiftObserved is bool
          && request.resource.data.capacityMismatchObserved is bool
          && request.resource.data.unregisteredShipmentObserved is bool
          && (
            request.resource.data.latitude == null
            || (
              request.resource.data.latitude is number
              && request.resource.data.latitude >= -90
              && request.resource.data.latitude <= 90
            )
          )
          && (
            request.resource.data.longitude == null
            || (
              request.resource.data.longitude is number
              && request.resource.data.longitude >= -180
              && request.resource.data.longitude <= 180
            )
          )
          && (
            (
              request.resource.data.latitude == null
              && request.resource.data.longitude == null
            )
            || (
              request.resource.data.latitude is number
              && request.resource.data.longitude is number
            )
          )
          && (
            request.resource.data.monthlyCapacity == null
            || (
              request.resource.data.monthlyCapacity is int
              && request.resource.data.monthlyCapacity >= 0
              && request.resource.data.capacityUnit is string
              && request.resource.data.capacityUnit.size() > 0
              && request.resource.data.capacityUnit.size() <= 80
            )
          )
          && (
            request.resource.data.lastVerifiedAt == null
            || request.resource.data.lastVerifiedAt is timestamp
          )
          && (
            request.resource.data.authorizationStatus != 'authorized'
            || request.resource.data.productionAuthorized == true
            || request.resource.data.storageAuthorized == true
            || request.resource.data.packagingAuthorized == true
            || request.resource.data.labelPrintingAuthorized == true
            || request.resource.data.destructionAuthorized == true
          )
          && (
            request.resource.data.facilityType
                != 'suspected_unauthorized_site'
            || request.resource.data.authorizationStatus != 'authorized'
          );
    }

    // ============================================================
    // FASON ÜRETİM VE TEDARİK GÜVENLİĞİ — KORUMA KONTROLLERİ
    // tenantId, marka hesabının Firebase Auth UID değeridir.
    // Kontrol kodu, marka ve oluşturma alanları değiştirilemez.
    // Fiziksel silme kapalıdır; kayıtlar gerekçeyle arşivlenir.
    // ============================================================

    function ssOptionalTimestamp(value) {
      return value == null || value is timestamp;
    }

    function ssProtectionControlIsValid() {
      return request.resource.data.keys().size() == 35
          && request.resource.data.keys().hasOnly([
            'tenantId',
            'brandId',
            'controlCode',
            'controlCodeNormalized',
            'title',
            'controlType',
            'scope',
            'status',
            'result',
            'riskLevel',
            'partnerId',
            'facilityId',
            'description',
            'assignedToId',
            'assignedToName',
            'plannedAt',
            'startedAt',
            'completedAt',
            'nextControlAt',
            'findings',
            'evidenceDocumentIds',
            'relatedProductIds',
            'correctiveAction',
            'correctiveActionOwnerId',
            'correctiveActionOwnerName',
            'correctiveActionDueAt',
            'correctiveActionCompletedAt',
            'notes',
            'archiveReason',
            'archivedAt',
            'metadata',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])
          && isValidRequiredText(request.resource.data.tenantId, 160)
          && isValidRequiredText(request.resource.data.brandId, 160)
          && isValidRequiredText(request.resource.data.controlCode, 100)
          && isValidRequiredText(
            request.resource.data.controlCodeNormalized,
            100
          )
          && request.resource.data.controlCodeNormalized
              == request.resource.data.controlCode.upper()
          && isValidRequiredText(request.resource.data.title, 200)
          && (request.resource.data.controlType is string && request.resource.data.controlType.matches('^(?:identity_verification|authorization_review|facility_inspection|production_security|capacity_consistency|raw_material_traceability|packaging_and_label_security|shipment_security|destruction_verification|subcontractor_review|document_and_certificate_review|incident_follow_up|custom)$'))
          && (request.resource.data.scope is string && request.resource.data.scope.matches('^(?:partner|facility|partner_and_facility)$'))
          && (request.resource.data.status is string && request.resource.data.status.matches('^(?:draft|planned|in_progress|completed|overdue|cancelled|archived)$'))
          && (request.resource.data.result is string && request.resource.data.result.matches('^(?:not_evaluated|passed|passed_with_observation|failed|critical_failure|not_applicable)$'))
          && mkIsSignalRiskLevel(request.resource.data.riskLevel)
          && (
            (
              request.resource.data.scope == 'partner'
              && request.resource.data.partnerId is string
              && request.resource.data.partnerId.size() > 0
              && request.resource.data.facilityId == null
            )
            || (
              request.resource.data.scope == 'facility'
              && request.resource.data.partnerId == null
              && request.resource.data.facilityId is string
              && request.resource.data.facilityId.size() > 0
            )
            || (
              request.resource.data.scope == 'partner_and_facility'
              && request.resource.data.partnerId is string
              && request.resource.data.partnerId.size() > 0
              && request.resource.data.facilityId is string
              && request.resource.data.facilityId.size() > 0
            )
          )
          && isValidOptionalText(request.resource.data.description, 5000)
          && isValidOptionalText(request.resource.data.findings, 10000)
          && (
            request.resource.data.correctiveAction == null
            || request.resource.data.correctiveAction is string
          )
          && request.resource.data.evidenceDocumentIds is list
          && request.resource.data.relatedProductIds is list
          && request.resource.data.metadata is map
          && ssOptionalTimestamp(request.resource.data.plannedAt)
          && ssOptionalTimestamp(request.resource.data.startedAt)
          && ssOptionalTimestamp(request.resource.data.completedAt)
          && ssOptionalTimestamp(request.resource.data.nextControlAt)
          && ssOptionalTimestamp(
            request.resource.data.correctiveActionDueAt
          )
          && ssOptionalTimestamp(
            request.resource.data.correctiveActionCompletedAt
          )
          && ssOptionalTimestamp(request.resource.data.archivedAt)
          && (
            request.resource.data.status != 'completed'
            || (
              request.resource.data.completedAt is timestamp
              && request.resource.data.result != 'not_evaluated'
            )
          )
          && (
            !(
              (request.resource.data.result is string && request.resource.data.result.matches('^(?:failed|critical_failure)$'))
            )
            || (
              request.resource.data.findings is string
              && request.resource.data.findings.size() > 0
              && request.resource.data.correctiveAction is string
              && request.resource.data.correctiveAction.size() > 0
            )
          )
          && (
            request.resource.data.status != 'archived'
            || (
              request.resource.data.archiveReason is string
              && request.resource.data.archiveReason.size() > 0
              && request.resource.data.archivedAt is timestamp
            )
          );
    }

    match /supply_security_protection_controls/{controlId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

     allow create: if false;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.controlCode
              == resource.data.controlCode
          && request.resource.data.controlCodeNormalized
              == resource.data.controlCodeNormalized
          && request.resource.data.createdAt
              == resource.data.createdAt
          && request.resource.data.createdBy
              == resource.data.createdBy
          && resource.data.status != 'archived'
          && ssProtectionControlIsValid()
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if false;
    }
    match /supply_security_partners/{partnerId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && ssPartnerIsValid()
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == null;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.partnerCode == resource.data.partnerCode
          && request.resource.data.partnerCodeNormalized
              == resource.data.partnerCodeNormalized
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && ssPartnerIsValid()
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.status == 'archived'
          && resource.data.archiveReason is string
          && resource.data.archiveReason.size() > 0
          && resource.data.archivedAt is timestamp
          && resource.data.relatedFacilityIds.size() == 0
          && resource.data.relatedProductIds.size() == 0
          && resource.data.certificateDocumentIds.size() == 0;
    }
    // ============================================================
    // FASON ÜRETİM VE TEDARİK GÜVENLİĞİ — TESİS SİCİLİ
    // tenantId, marka hesabının Firebase Auth UID değeridir.
    // Marka, partner, tesis kodu ve oluşturma alanları değiştirilemez.
    // ============================================================

    match /supply_security_facilities/{facilityId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.tenantId == request.auth.uid
          && ssFacilityIsValid()
          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == null;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.partnerId == resource.data.partnerId
          && request.resource.data.facilityCode
              == resource.data.facilityCode
          && request.resource.data.facilityCodeNormalized
              == resource.data.facilityCodeNormalized
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy
          && ssFacilityIsValid()
          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.status == 'archived'
          && resource.data.archiveReason is string
          && resource.data.archiveReason.size() > 0
          && resource.data.archivedAt is timestamp
          && resource.data.relatedProductIds.size() == 0
          && resource.data.certificateDocumentIds.size() == 0
          && resource.data.auditDocumentIds.size() == 0;
    }
    // ============================================================
    // FİKRİ MÜLKİYET — HAK SAHİPLİĞİ KAYITLARI
    // tenantId, marka hesabının Firebase Auth UID değeridir.
    // Hak sahipliği kimliği, tenant ve ilk oluşturma bilgileri
    // güncelleme sırasında değiştirilemez.
    // ============================================================

    match /ip_ownership_records/{ownershipRecordId} {
      allow read: if request.auth != null
          && resource.data.tenantId == request.auth.uid;

      allow create: if request.auth != null
          && request.resource.data.keys().size() == 42
          && request.resource.data.keys().hasOnly([
            'tenantId',
            'brandId',
            'assetId',
            'recordCode',
            'ownershipKind',
            'partyType',
            'partyName',
            'partyId',
            'partyExternalId',
            'partyCountryCode',
            'partyRegistrationNumber',
            'partyTaxNumber',
            'partyContactEmail',
            'acquisitionType',
            'status',
            'ownershipPercentage',
            'jurisdictionScope',
            'countryCodes',
            'regionCode',
            'rightId',
            'sourceOwnershipRecordId',
            'previousOwnershipRecordId',
            'nextOwnershipRecordId',
            'agreementNumber',
            'agreementDate',
            'effectiveFrom',
            'effectiveUntil',
            'isExclusive',
            'isPrimaryOwner',
            'isBeneficialOwner',
            'isOwnershipVerified',
            'verificationDate',
            'verifiedBy',
            'documentIds',
            'relationshipIds',
            'transferChainRecordIds',
            'notes',
            'metadata',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])

          && request.resource.data.tenantId == request.auth.uid
          && request.resource.data.tenantId is string
          && request.resource.data.tenantId.size() > 0

          && request.resource.data.brandId is string
          && request.resource.data.brandId.size() > 0

          && request.resource.data.assetId is string
          && request.resource.data.assetId.size() > 0

          && request.resource.data.recordCode is string
          && request.resource.data.recordCode.size() > 0
          && request.resource.data.recordCode.size() <= 100

          && request.resource.data.partyName is string
          && request.resource.data.partyName.size() > 0
          && request.resource.data.partyName.size() <= 300

          && mkIsOwnershipKind(request.resource.data.ownershipKind)

          && mkIsPartyType(request.resource.data.partyType)

          && mkIsAcquisitionType(request.resource.data.acquisitionType)

          && mkIsOwnershipStatus(request.resource.data.status)

          && (request.resource.data.jurisdictionScope is string && request.resource.data.jurisdictionScope.matches('^(?:national|regional|international|contractual|unregistered)$'))

          && request.resource.data.ownershipPercentage is number
          && request.resource.data.ownershipPercentage >= 0
          && request.resource.data.ownershipPercentage <= 100

          && request.resource.data.countryCodes is list
          && request.resource.data.documentIds is list
          && request.resource.data.relationshipIds is list
          && request.resource.data.transferChainRecordIds is list
          && request.resource.data.metadata is map

          && request.resource.data.isExclusive is bool
          && request.resource.data.isPrimaryOwner is bool
          && request.resource.data.isBeneficialOwner is bool
          && request.resource.data.isOwnershipVerified is bool

          && request.resource.data.createdAt == request.time
          && request.resource.data.createdBy == request.auth.uid

          && request.resource.data.updatedAt == null
          && request.resource.data.updatedBy == null;

      allow update: if request.auth != null
          && resource.data.tenantId == request.auth.uid

          && request.resource.data.keys().hasAll([
            'tenantId',
            'brandId',
            'assetId',
            'recordCode',
            'ownershipKind',
            'partyType',
            'partyName',
            'acquisitionType',
            'status',
            'ownershipPercentage',
            'jurisdictionScope',
            'countryCodes',
            'isExclusive',
            'isPrimaryOwner',
            'isBeneficialOwner',
            'isOwnershipVerified',
            'documentIds',
            'relationshipIds',
            'transferChainRecordIds',
            'metadata',
            'createdAt',
            'createdBy',
            'updatedAt',
            'updatedBy'
          ])

          && request.resource.data.tenantId == resource.data.tenantId
          && request.resource.data.brandId == resource.data.brandId
          && request.resource.data.assetId == resource.data.assetId
          && request.resource.data.recordCode == resource.data.recordCode
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.createdBy == resource.data.createdBy

          && mkIsOwnershipKind(request.resource.data.ownershipKind)

          && mkIsPartyType(request.resource.data.partyType)

          && mkIsAcquisitionType(request.resource.data.acquisitionType)

          && mkIsOwnershipStatus(request.resource.data.status)

          && (request.resource.data.jurisdictionScope is string && request.resource.data.jurisdictionScope.matches('^(?:national|regional|international|contractual|unregistered)$'))

          && request.resource.data.partyName is string
          && request.resource.data.partyName.size() > 0
          && request.resource.data.partyName.size() <= 300

          && request.resource.data.ownershipPercentage is number
          && request.resource.data.ownershipPercentage >= 0
          && request.resource.data.ownershipPercentage <= 100

          && request.resource.data.countryCodes is list
          && request.resource.data.documentIds is list
          && request.resource.data.relationshipIds is list
          && request.resource.data.transferChainRecordIds is list
          && request.resource.data.metadata is map

          && request.resource.data.isExclusive is bool
          && request.resource.data.isPrimaryOwner is bool
          && request.resource.data.isBeneficialOwner is bool
          && request.resource.data.isOwnershipVerified is bool

          && request.resource.data.updatedAt == request.time
          && request.resource.data.updatedBy == request.auth.uid;

      allow delete: if request.auth != null
          && resource.data.tenantId == request.auth.uid
          && resource.data.status == 'draft'
          && resource.data.documentIds.size() == 0
          && resource.data.relationshipIds.size() == 0
          && resource.data.transferChainRecordIds.size() == 0
          && resource.data.sourceOwnershipRecordId == null
          && resource.data.previousOwnershipRecordId == null
          && resource.data.nextOwnershipRecordId == null
          && resource.data.rightId == null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidRequiredText(value, maxLength) {
      return value is string
          && value.size() > 0
          && value.size() <= maxLength;
    }

    function isValidOptionalText(value, maxLength) {
      return value == null
          || (value is string && value.size() <= maxLength);
    }

    match /brandApplications/{applicationId} {
      allow create: if
          request.resource.data.keys().hasAll([
            'companyName',
            'brandName',
            'businessType',
            'sector',
            'authorizedPerson',
            'email',
            'phone',
            'taxNumber',
            'website',
            'problemDescription',
            'status',
            'createdAt'
          ])
          && request.resource.data.keys().hasOnly([
            'companyName',
            'brandName',
            'businessType',
            'sector',
            'authorizedPerson',
            'email',
            'phone',
            'taxNumber',
            'website',
            'problemDescription',
            'status',
            'createdAt'
          ])
          && isValidRequiredText(
            request.resource.data.companyName,
            180
          )
          && isValidRequiredText(
            request.resource.data.brandName,
            120
          )
          && isValidRequiredText(
            request.resource.data.businessType,
            60
          )
          && isValidRequiredText(
            request.resource.data.sector,
            80
          )
          && isValidRequiredText(
            request.resource.data.authorizedPerson,
            120
          )
          && isValidRequiredText(
            request.resource.data.email,
            180
          )
          && request.resource.data.email.matches(
            '^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$'
          )
          && isValidRequiredText(
            request.resource.data.phone,
            40
          )
          && isValidRequiredText(
            request.resource.data.taxNumber,
            30
          )
          && isValidOptionalText(
            request.resource.data.website,
            300
          )
          && isValidRequiredText(
            request.resource.data.problemDescription,
            2000
          )
          && request.resource.data.status == 'pending'
          && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }
match /brands/{brandUid}/products/{productId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'name',
        'brandName',
        'sku',
        'category',
        'description',
        'isActive',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'name',
        'brandName',
        'sku',
        'category',
        'description',
        'isActive',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.name is string
      && request.resource.data.name.size() >= 2
      && request.resource.data.name.size() <= 160
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.sku is string
      && request.resource.data.sku.size() <= 80
      && request.resource.data.category is string
      && request.resource.data.category.size() >= 2
      && request.resource.data.category.size() <= 100
      && request.resource.data.description is string
      && request.resource.data.description.size() <= 2000
      && request.resource.data.isActive is bool
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  allow update: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid;
}
match /brands/{brandUid}/productionBatches/{batchId} {
  allow read: if request.auth != null
      && request.auth.uid == brandUid;

  allow create: if request.auth != null
      && request.auth.uid == brandUid
      && request.resource.data.keys().hasAll([
        'productId',
        'productName',
        'batchNumber',
        'productionType',
        'authorizedQuantity',
        'defectQuantity',
        'shippedQuantity',
        'productionDate',
        'notes',
        'status',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'productId',
        'productName',
        'batchNumber',
        'productionType',
        'authorizedQuantity',
        'defectQuantity',
        'shippedQuantity',
        'productionDate',
        'notes',
        'status',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.productId is string
      && request.resource.data.productId.size() > 0
      && request.resource.data.productId.size() <= 160
      && request.resource.data.productName is string
      && request.resource.data.productName.size() > 0
      && request.resource.data.productName.size() <= 160
      && request.resource.data.batchNumber is string
      && request.resource.data.batchNumber.size() >= 2
      && request.resource.data.batchNumber.size() <= 100
      && request.resource.data.productionType is string
      && request.resource.data.productionType in [
        'Kendi üretim',
        'Fason üretim',
        'İthalat'
      ]
      && request.resource.data.authorizedQuantity is int
      && request.resource.data.authorizedQuantity > 0
      && request.resource.data.defectQuantity is int
      && request.resource.data.defectQuantity >= 0
      && request.resource.data.shippedQuantity is int
      && request.resource.data.shippedQuantity >= 0
      && request.resource.data.defectQuantity
          + request.resource.data.shippedQuantity
          <= request.resource.data.authorizedQuantity
      && request.resource.data.productionDate is timestamp
      && request.resource.data.notes is string
      && request.resource.data.notes.size() <= 2000
      && request.resource.data.status in [
        'planned',
        'in_production',
        'completed',
        'cancelled'
      ]
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;

  allow update: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.keys().hasOnly([
        'productId',
        'productName',
        'batchNumber',
        'productionType',
        'authorizedQuantity',
        'defectQuantity',
        'shippedQuantity',
        'productionDate',
        'notes',
        'status',
        'ownerUid',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && request.auth.uid == brandUid
      && resource.data.ownerUid == request.auth.uid;
}
match /productCodes/{codeId} {
  // Tüketici yalnız bildiği tekil kodu doğrudan sorgulayabilir.
  // Tüm kod koleksiyonu herkese açık şekilde listelenemez.
  allow read: if request.auth != null
    && resource.data.ownerUid == request.auth.uid;

  allow create: if request.auth != null
      && request.resource.data.keys().hasAll([
        'publicCode',
        'ownerUid',
        'brandName',
        'productId',
        'productName',
        'batchId',
        'batchNumber',
        'status',
        'scanCount',
        'firstVerifiedAt',
        'lastVerifiedAt',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasOnly([
        'publicCode',
        'ownerUid',
        'brandName',
        'productId',
        'productName',
        'batchId',
        'batchNumber',
        'status',
        'scanCount',
        'firstVerifiedAt',
        'lastVerifiedAt',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.publicCode == codeId
      && request.resource.data.publicCode is string
      && request.resource.data.publicCode.size() >= 10
      && request.resource.data.publicCode.size() <= 80
      && request.resource.data.ownerUid == request.auth.uid
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.productId is string
      && request.resource.data.productId.size() > 0
      && request.resource.data.productName is string
      && request.resource.data.productName.size() > 0
      && request.resource.data.productName.size() <= 160
      && request.resource.data.batchId is string
      && request.resource.data.batchId.size() > 0
      && request.resource.data.batchNumber is string
      && request.resource.data.batchNumber.size() >= 2
      && request.resource.data.batchNumber.size() <= 100
      && request.resource.data.status == 'active'
      && request.resource.data.scanCount == 0
      && request.resource.data.firstVerifiedAt == null
      && request.resource.data.lastVerifiedAt == null
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time
      && exists(
        /databases/$(database)/documents/brands/$(request.auth.uid)/products/$(request.resource.data.productId)
      )
      && exists(
        /databases/$(database)/documents/brands/$(request.auth.uid)/productionBatches/$(request.resource.data.batchId)
      )
      && get(
        /databases/$(database)/documents/brands/$(request.auth.uid)/productionBatches/$(request.resource.data.batchId)
      ).data.productId == request.resource.data.productId;

  // Marka sahibi yalnız kodun durumunu değiştirebilir.
  // Tarama sayaçları ileride güvenli sunucu fonksiyonuyla güncellenecek.
  allow update: if request.auth != null
      && resource.data.ownerUid == request.auth.uid
      && request.resource.data.ownerUid == resource.data.ownerUid
      && request.resource.data.publicCode == resource.data.publicCode
      && request.resource.data.createdAt == resource.data.createdAt
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'updatedAt'
      ])
      && request.resource.data.status in [
        'active',
        'blocked',
        'revoked'
      ]
      && request.resource.data.updatedAt == request.time;

  allow delete: if request.auth != null
      && resource.data.ownerUid == request.auth.uid;
}
match /publicProductCodes/{codeId} {
  allow get: if true;
  allow list: if false;

  allow create: if request.auth != null
      && request.resource.data.keys().hasAll([
        'publicCode',
        'brandName',
        'productName',
        'batchNumber',
        'status',
        'createdAt'
      ])
      && request.resource.data.keys().hasOnly([
        'publicCode',
        'brandName',
        'productName',
        'batchNumber',
        'status',
        'createdAt'
      ])
      && request.resource.data.publicCode == codeId
      && request.resource.data.publicCode is string
      && request.resource.data.publicCode.size() >= 10
      && request.resource.data.publicCode.size() <= 80
      && request.resource.data.brandName is string
      && request.resource.data.brandName.size() >= 2
      && request.resource.data.brandName.size() <= 120
      && request.resource.data.productName is string
      && request.resource.data.productName.size() >= 2
      && request.resource.data.productName.size() <= 160
      && request.resource.data.batchNumber is string
      && request.resource.data.batchNumber.size() >= 2
      && request.resource.data.batchNumber.size() <= 100
      && request.resource.data.status == 'active'
      && request.resource.data.createdAt == request.time

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.ownerUid == request.auth.uid

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.publicCode == request.resource.data.publicCode

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.brandName == request.resource.data.brandName

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.productName == request.resource.data.productName

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.batchNumber == request.resource.data.batchNumber

      && getAfter(
        /databases/$(database)/documents/productCodes/$(codeId)
      ).data.status == request.resource.data.status;

  allow update, delete: if false;
}
    match /{document=**} {
      allow read, write: if false;
    }
  }
}